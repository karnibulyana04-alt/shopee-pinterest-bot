# ==== Pinterest Developer App ====
# Daftar app di https://developers.pinterest.com/apps/
PINTEREST_APP_ID=isi_app_id_kamu
PINTEREST_APP_SECRET=isi_app_secret_kamu
# Redirect URI harus SAMA PERSIS dengan yang didaftarkan di dashboard Pinterest app
PINTEREST_REDIRECT_URI=http://localhost:3000/auth/pinterest/callback

# ==== Anthropic (Claude) API untuk generate caption ====
# Daftar / ambil key di https://console.anthropic.com
ANTHROPIC_API_KEY=isi_api_key_kamu

# ==== (Opsional) AI Image Generation ====
# Kalau mau generate gambar AI selain foto produk Shopee, isi salah satu provider image gen kamu
# Contoh pakai OpenAI images atau provider lain, sesuaikan di services/imageGen.js
IMAGE_GEN_API_KEY=

# ==== App Config ====
PORT=3000
BASE_URL=http://localhost:3000
