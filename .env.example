# ==== Groq API (GRATIS, buat generate caption) ====
# Daftar API key gratis (gak perlu kartu kredit) di:
# https://console.groq.com/keys
GROQ_API_KEY=isi_api_key_kamu

# ==== Make.com Webhook (buat posting ke Pinterest) ====
# Buat scenario di Make.com: Webhook trigger -> Pinterest "Create a Pin" action
# Connect akun Pinterest kamu LANGSUNG di dalam Make.com (bukan di app ini)
# Copy URL webhook-nya ke sini:
MAKE_WEBHOOK_URL=isi_webhook_url_dari_make_com

# ==== App Config ====
PORT=3000
BASE_URL=http://localhost:3000
